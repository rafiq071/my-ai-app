# Supabase (required for the app)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI generation (required for Generate button — add to .env for local dev)
OPENAI_API_KEY=sk-...

# Optional: override API base URL (e.g. for local dev if API runs elsewhere)
# VITE_API_URL=https://your-deployment.vercel.app

# Set these in Vercel: Project Settings → Environment Variables
